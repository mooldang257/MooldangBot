# 🔍 [MooldangBot Zero-Git Policy .gitignore]

# 1. Visual Studio 캐시 및 로컬 설정
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# 2. 빌드 결과물 (컴파일된 파일들)
bin/
obj/
publish/

# 3. 🔐 보안 및 환경 설정 (GITHUB 업로드 절대 금지)
#appsettings.json
#appsettings.Dev.json
#appsettings.Production.json
#appsettings.Development.json
.env
.env.*
secrets/

# 4. 연구, 로그 및 임시 파일 (서버 빌드 불필요)
scripts/archive/
scripts/logs/
*.sql
*.zip
*.rar
*.md.tmp
*.log

# 5. 로컬 데이터 폴더 (볼륨 매핑 권장)
wwwroot/images/avatars/
db_data/

# 6. 기타 시스템 파일
.DS_Store
Thumbs.db