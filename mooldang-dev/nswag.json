      "referencePaths": [],
      "useDocumentProvider": false,
      "output": null,
      "outputType": "OpenApi3",
      "newLineBehavior": "Auto",
      "assemblyConfig": null,
      "project": null,
      "msBuildProjectParameters": null,
      "projectUsed": false
    }
  },
  "codeGenerators": {
    "openApiToTypeScriptClient": {
      "className": "{controller}Client",
      "moduleName": "",
      "namespace": "",
      "typeScriptVersion": 5.0,
      "template": "Fetch",
      "promiseType": "Promise",
      "httpClass": "HttpClient",
      "useSingletonFreeProxy": false,
      "injectionTokenType": "OpaqueToken",
